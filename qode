#!/bin/bash
# run.sh

set -e

GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

# ─── 1. Настройки ──────────────────────────────────────────────
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_PATH="${1:-$(pwd)}"
PROJECT_PATH="$(cd "${PROJECT_PATH}" && pwd)"
PROJECT_NAME="$(basename "${PROJECT_PATH}")"
SESSION_NAME="qwen-${PROJECT_NAME}"
CONTAINER_NAME="qwen-${PROJECT_NAME}-$(date +%s)"
DEBUG_MODE="${QWEN_DEBUG_RUN:-0}"

# ─── 2. Проверка пути ──────────────────────────────────────────
if [ ! -d "${PROJECT_PATH}" ]; then
    echo -e "${RED}❌ Путь не существует: ${PROJECT_PATH}${NC}"
    exit 1
fi

# ─── 3. Определение тега образа ─────────────────────────────────
# Если указана переменная QODE_VERSION, используем её как тег образа; иначе ищем последний образ
if [ -n "${QODE_VERSION}" ]; then
    IMAGE_TAG="${QODE_VERSION}"
    echo -e "${GREEN}✅ Используем образ qwen-code с указанным тегом:${BLUE} $IMAGE_TAG${NC}"
else
    IMAGE_TAG=$(docker images --filter=reference='qwen-code:*' --format '{{.Tag}} {{.CreatedAt}}' | sort -r -k2 | head -n1 | awk '{print $1}')
    if [ -z "$IMAGE_TAG" ]; then
        echo -e "${RED}❌ Не найден образ qwen-code с любым тегом!${NC}"
        exit 1
    fi
    echo -e "${GREEN}✅ Выбран образ qwen-code:${BLUE} $IMAGE_TAG${NC}"
fi

# ─── 4. Подготовка директории логов ───────────────────────────
SESSION_LOG_DIR="${PROJECT_PATH}/.qwen/sessions"
mkdir -p "${SESSION_LOG_DIR}"
chmod 777 "${SESSION_LOG_DIR}" 2>/dev/null || true

echo -e "${GREEN}📝 Лог сессии: ${BLUE}${SESSION_LOG_DIR}/session.log${NC}"
echo ""

# ─── 5. tmux ───────────────────────────────────────────────────
if ! command -v tmux &> /dev/null; then
    echo -e "${RED}❌ tmux не найден!${NC}"
    echo -e "   Установите: ${BLUE}brew install tmux${NC} (macOS) или ${BLUE}sudo apt install tmux${NC} (Linux)"
    exit 1
fi

echo -e "${GREEN}🔹 Запуск в tmux-сессии: ${SESSION_NAME}${NC}"

if tmux has-session -t "${SESSION_NAME}" 2>/dev/null; then
    echo -e "${YELLOW}⚠️  Сессия уже существует.${NC}"
    echo -e "   Подключиться: ${BLUE}tmux attach -t ${SESSION_NAME}${NC}"
    echo -e "   Убить старую: ${BLUE}tmux kill-session -t ${SESSION_NAME}${NC}"
    echo ""
    read -p "Подключиться к существующей сессии? [y/N] " -n 1 -r
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        tmux attach -t "${SESSION_NAME}"
        exit 0
    else
        tmux kill-session -t "${SESSION_NAME}"
    fi
fi

# ─── 6. Собираем команду docker run в файл и исполняем ─────────
#
# ИСПРАВЛЕНИЕ для macOS: mktemp может глючить, создаём файл явно
#
TMP_SCRIPT="/tmp/qwen-run-${$}-${RANDOM}.sh"

# Проверяем, что /tmp доступен
if [ ! -d "/tmp" ] || [ ! -w "/tmp" ]; then
    echo -e "${RED}❌ /tmp недоступен для записи${NC}"
    exit 1
fi

# Создаём файл явно (надёжнее чем mktemp на macOS)
touch "${TMP_SCRIPT}" || {
    echo -e "${RED}❌ Не удалось создать временный файл: ${TMP_SCRIPT}${NC}"
    echo -e "   Попробуйте: ${BLUE}sudo chmod 1777 /tmp${NC}"
    exit 1
}

chmod +x "${TMP_SCRIPT}" || {
    echo -e "${RED}❌ Не удалось сделать файл исполняемым${NC}"
    rm -f "${TMP_SCRIPT}"
    exit 1
}

RM_FLAG="--rm"
[ "${DEBUG_MODE}" = "1" ] && RM_FLAG=""

cat > "${TMP_SCRIPT}" <<DOCKER_CMD
#!/bin/bash
set -e
# Убедимся, что папка сессий существует и доступна для записи
mkdir -p "${SESSION_LOG_DIR}"
chmod 777 "${SESSION_LOG_DIR}" 2>/dev/null || true
docker run -it ${RM_FLAG} \\
    --name "${CONTAINER_NAME}" \\
    -v "${PROJECT_PATH}:/workspace/${PROJECT_NAME}" \\
    -v "${HOME}/.qwen:/home/agent/.qwen:ro" \\
    -v "${HOME}/.qwen/agents:/home/agent/.qwen/agents" \\
    -v "${HOME}/.qwen/debug:/home/agent/.qwen/debug" \\
    -v "${HOME}/.qwen/projects:/home/agent/.qwen/projects" \\
    -v "${HOME}/.qwen/skills:/home/agent/.qwen/skills" \\
    -v "${HOME}/.qwen/tmp:/home/agent/.qwen/tmp" \\
    -v "${HOME}/.qwen/todos:/home/agent/.qwen/todos" \\
    -v "${HOME}/.ssh:/home/agent/.ssh:ro" \\
    -v "${HOME}/.kube:/home/agent/.kube:ro" \\
    -v "/etc/hosts:/etc/hosts:ro" \\
    -e QWEN_MODEL="${QWEN_MODEL:-qwen-max}" \\
    -e QWEN_DEBUG=1 \\
    -w /workspace \\
    --user agent \\
    --entrypoint /usr/local/bin/entrypoint.sh \\
    qwen-code:${IMAGE_TAG} ${PROJECT_NAME}
# Убираем tmp-скрипт после завершения
rm -f "${TMP_SCRIPT}"
DOCKER_CMD

# Проверяем, что файл записался
if [ ! -s "${TMP_SCRIPT}" ]; then
    echo -e "${RED}❌ Временный файл пустой${NC}"
    rm -f "${TMP_SCRIPT}"
    exit 1
fi

# ─── 7. Запуск в tmux ──────────────────────────────────────────
tmux new-session -d -s "${SESSION_NAME}" "${TMP_SCRIPT}"

echo -e "${GREEN}✅ Контейнер запущен в tmux.${NC}"
echo -e ""
echo -e "   ${BLUE}Управление:${NC}"
echo -e "   • Отключиться:  ${BLUE}Ctrl+B, затем D${NC}"
echo -e "   • Вернуться:    ${BLUE}tmux attach -t ${SESSION_NAME}${NC}"
echo -e "   • Убить сессию: ${BLUE}tmux kill-session -t ${SESSION_NAME}${NC}"
echo -e ""
echo -e "   ${BLUE}Логи qwen:${NC} ~/.qwen/debug/"
echo ""

if [ "${DEBUG_MODE}" = "1" ]; then
    echo -e "   ${YELLOW}🔧 Отладочный режим активен.${NC}"
    echo -e "   Если контейнер упадёт:"
    echo -e "   ${BLUE}docker logs ${CONTAINER_NAME}${NC}"
    echo -e "   ${BLUE}docker inspect ${CONTAINER_NAME}${NC}"
    echo -e "   ${BLUE}docker rm ${CONTAINER_NAME}${NC}"
    echo ""
fi

tmux attach -t "${SESSION_NAME}"
